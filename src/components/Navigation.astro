---
import ThemeToggle from "./ThemeToggle.astro";
---

<div class="justify-center w-full nav border-x border-t border-b">
  <div
    class="text-center items-center w-full flex flex-col justify-between md:p-8 md:flex-row"
  >
    <a
      href="/"
      class="flex items-center gap-2 p-4 md:p-0"
    >
      <img
        src="/images/logo.svg"
        alt="MarkMcDermott.io"
        class="nav-logo h-6"
      />
      <span class="nav-text font-medium text-[15px]">MarkMcDermott.io</span>
    </a>
    <div
      class="flex flex-col md:flex-row md:items-center w-full md:w-auto"
    >
      <a
        href="/about"
        class="w-full md:w-fit bg-white duration-200 font-black text-[#1e1e1e] border-slate-300 dark:border-gray-400 hover:bg-gray-200 px-6 md:px-4 lg:px-6 py-4 md:rounded-full md:border text-center text-xs uppercase"
        >About</a
      >
      <a
        href="/blog"
        class="w-full md:w-fit bg-white duration-200 font-black text-[#1e1e1e] border-slate-300 dark:border-gray-400 hover:bg-gray-200 px-6 md:px-4 lg:px-6 py-4 md:rounded-full md:border text-center text-xs uppercase md:mx-4"
        >Blog</a
      >
      <a
        href="https://github.com/mark-mcdermott"
        class="w-full md:w-fit bg-orange duration-200 font-black border-slate-300 dark:border-gray-400 hover:bg-orange-600 text-white px-6 md:px-4 lg:px-6 py-4 md:mx-4 md:rounded-full md:border text-black hover:text-white text-center text-xs uppercase"
        >Github</a
      >
      <div class="flex items-center justify-center p-4 md:p-0 md:ml-4">
        <ThemeToggle />
      </div>
    </div>
  </div>
</div>

<style>
  :global([data-theme="dark"]) .nav-logo {
    filter: invert(93%) sepia(10%) saturate(200%) hue-rotate(10deg);
  }

  .nav-text {
    color: #1e1e1e;
  }

  :global([data-theme="dark"]) .nav-text {
    color: #e7e7d8;
  }
</style>
