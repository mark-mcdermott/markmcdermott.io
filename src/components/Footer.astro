---
import WeatherIcon from './WeatherIcon.astro';
---
<footer>
  <p class="footer__meta">
    <span class="footer__clock"></span>&nbsp;&middot; austin, tx <WeatherIcon />
  </p>
  <div class="footer__right">
    <div class="footer__social">
      <a href="https://github.com/mark-mcdermott" target="_blank" rel="noopener noreferrer" title="github">[gh]</a>
      <a href="https://bsky.app/profile/mark-mcdermott.bsky.social" target="_blank" rel="noopener noreferrer" title="bluesky">[bs]</a>
      <a href="https://www.linkedin.com/in/mark-mcdermott-6a174916" target="_blank" rel="noopener noreferrer" title="linkedin">[in]</a>
    </div>
    <a class="ready" href="mailto:hello@markmcdermott.io">Ready.</a>
  </div>
</footer>


<style lang="scss">
  @use '../styles/abstracts' as *;
  footer {
    margin-bottom: $spacing-unit * 5;
    margin-top: $spacing-unit * 7;
    padding: ($spacing-unit * 2) 0 0;
    display: flex;
    justify-content: space-between;
    @include hyphen-border;
    font-size: 0.8rem;

    .footer__meta {
      @include c64-type;
      text-transform: lowercase;
      display: flex;
      align-items: center;
      gap: 0.25em;
      word-spacing: -0.9em;
      letter-spacing: -0.1em;
    }

    .footer__right {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .footer__social {
      display: flex;
      gap: 5px;

      a {
        @include c64-type;
        text-decoration: none;
        text-transform: lowercase;
        letter-spacing: -0.15em;
        color: var(--color-link);
        font-weight: normal;

        &:hover {
          color: var(--color-link-hover);
        }
      }
    }

    .ready {
      @include c64-type;
      color: var(--color-link);
      text-decoration: none;

      &:hover {
        color: var(--color-link-hover);
      }
    }

    @include mobile {
      flex-direction: column;
      align-items: center;
      gap: $spacing-unit;

      .footer__meta {
        display: none;
      }

      .footer__right {
        flex-direction: column;
        align-items: center;
      }
    }
  }
</style>

<script>
  const clock = document.querySelector('.footer__clock');
  function updateClock() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2, '0');
    const m = String(now.getMinutes()).padStart(2, '0');
    const s = String(now.getSeconds()).padStart(2, '0');
    if (clock) clock.textContent = `${h}:${m}:${s}`;
  }
  updateClock();
  setInterval(updateClock, 1000);
</script>
