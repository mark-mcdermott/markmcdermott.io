---
import BgGrid from "./BgGrid.astro";
import { Image } from "astro:assets";
import Frunk from "../assets/work/screenshot-frunk.png";
import ThemeForseen from "../assets/work/screenshot-theme-forseen.png";
import Xun from "../assets/work/screenshot-xun.png";
import Puravida from "../assets/work/screenshot-puravida.png";
import LogoFrunk from "../assets/work/logo-frunk.png";
import LogoThemeForseen from "../assets/work/logo-themeforseen.png";
import LogoXun from "../assets/work/logo-xun.png";
import LogoPuravida from "../assets/work/logo-puravida.png";

const projectsBase = [
  { name: "Frunk", description: "Car doc storage", image: Frunk, logo: LogoFrunk, url: "https://frunk.cloud" },
  { name: "Theme Forseen", description: "App theming tool", image: ThemeForseen, logo: LogoThemeForseen, url: "https://themeforseen.com/" },
  { name: "Xun", description: "Blog post publishing", image: Xun, logo: LogoXun, url: "https://github.com/mark-mcdermott/xun-notes" },
  { name: "Puravida", description: "Bash script", image: Puravida, logo: LogoPuravida, url: "https://github.com/mark-mcdermott/puravida" },
];
const projects = [...projectsBase, ...projectsBase];
---

<section class="work-slider border-x border-b">
  <div class="px-8 py-6 relative">
    <BgGrid />
    <h2 class="text-3xl font-black uppercase relative work-slider-title">
      Projects I've Built
    </h2>
  </div>
  <div class="relative border-t">
    <div
      class="absolute inset-y-0 left-0 right-0 flex items-center justify-between px-2 pointer-events-none z-10"
    >
      <button
        id="keen-slider-previous"
        aria-label="Previous slide"
        class="pointer-events-auto p-2 size-8 bg-white/80 hover:bg-white text-black rounded-full shadow transition cursor-pointer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="currentColor"
          viewBox="0 0 256 256"
        >
          <path
            d="M165.66,202.34a8,8,0,0,1-11.32,11.32l-80-80a8,8,0,0,1,0-11.32l80-80a8,8,0,0,1,11.32,11.32L91.31,128Z"
          ></path>
        </svg>
      </button>
      <button
        id="keen-slider-next"
        aria-label="Next slide"
        class="pointer-events-auto p-2 size-8 bg-white hover:bg-white text-black rounded-full shadow transition cursor-pointer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="currentColor"
          viewBox="0 0 256 256"
        >
          <path
            d="M181.66,133.66l-80,80a8,8,0,0,1-11.32-11.32L164.69,128,90.34,53.66a8,8,0,0,1,11.32-11.32l80,80A8,8,0,0,1,181.66,133.66Z"
          ></path>
        </svg>
      </button>
    </div>
    <div id="keen-slider" class="keen-slider relative">
      {
        projects.map(({ name, description, image, logo, url }) => (
          <div class="relative w-full keen-slider__slide">
            <a href={url} target="_blank" rel="noopener noreferrer" class="block group">
              <div class="project-image-wrapper">
                <Image src={image} alt={name} class="aspect-auto w-full" />
                <div class="project-image-overlay"></div>
                <div class="project-logo">
                  <Image src={logo} alt={`${name} logo`} width={300} height={80} class="w-full h-auto object-contain" />
                </div>
              </div>
              <div class="project-caption">
                <span class="project-title">{name}</span>
                <span class="project-separator">&middot;</span>
                <span class="project-desc">{description}</span>
              </div>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Keen Slider base styles */
  .keen-slider {
    display: flex;
    overflow: hidden;
    position: relative;
    user-select: none;
    -webkit-touch-callout: none;
    -khtml-user-select: none;
    touch-action: pan-y;
    -webkit-tap-highlight-color: transparent;
  }
  .keen-slider__slide {
    position: relative;
    overflow: visible;
    width: 100%;
    min-height: 100%;
  }

  .project-image-wrapper {
    position: relative;
    overflow: visible;
  }

  .project-image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .keen-slider:hover .project-image-overlay {
    opacity: 1;
  }

  .keen-slider__slide:hover .project-image-overlay {
    opacity: 0;
  }

  .project-logo {
    position: absolute;
    top: 35%;
    left: 50%;
    transform: translate(-50%, -50%);
    min-width: 300px;
    padding: 24px 40px;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 10;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 12px;
  }

  .keen-slider__slide:hover .project-logo {
    opacity: 1;
  }

  /* Project caption styles */
  .project-caption {
    padding: 0.875rem 0 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
  }

  .project-title {
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    text-transform: uppercase;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
  }

  .project-separator {
    color: rgba(255, 255, 255, 0.3);
    font-weight: 300;
  }

  .project-desc {
    color: rgba(255, 255, 255, 0.5);
    font-weight: 400;
    font-size: 0.75rem;
  }

  .group:hover .project-title {
    color: #ea580c;
    font-weight: 700;
  }

  .group:hover .project-desc {
    color: #ea580c;
    font-weight: 600;
  }
</style>

<style is:global>
  [data-theme="dark"] .work-slider-title {
    color: #e7e7d8 !important;
  }
</style>

<script>
  import KeenSlider from "https://cdn.jsdelivr.net/npm/keen-slider@6.8.6/+esm";

  document.addEventListener("astro:page-load", () => {
    const autoplay = (slider: any) => {
      let timeout: ReturnType<typeof setTimeout>;
      let mouseOver = false;

      function clearNextTimeout() {
        clearTimeout(timeout);
      }

      function nextTimeout() {
        clearTimeout(timeout);
        if (mouseOver) return;
        timeout = setTimeout(() => {
          slider.next();
        }, 2000);
      }

      slider.on("created", () => {
        slider.container.addEventListener("mouseover", () => {
          mouseOver = true;
          clearNextTimeout();
        });
        slider.container.addEventListener("mouseout", () => {
          mouseOver = false;
          nextTimeout();
        });
        nextTimeout();
      });
      slider.on("dragStarted", clearNextTimeout);
      slider.on("animationEnded", nextTimeout);
      slider.on("updated", nextTimeout);
    };

    const sliderEl = document.getElementById("keen-slider");
    if (!sliderEl) {
      console.warn("Slider element not found");
      return;
    }

    const keenSlider = new KeenSlider(
      sliderEl,
      {
        initial: 5,
        loop: true,
        defaultAnimation: {
          duration: 1000,
        },
        detailsChanged: (s: any) => {
          s.slides.forEach((element: HTMLElement, idx: number) => {
            const portion = s.track.details.slides[idx].portion;
            element.style.opacity = String(Math.max(0.3, portion));
          });
        },
        slides: {
          origin: "center",
          perView: 2.2,
          spacing: 12,
        },
        breakpoints: {
          "(min-width: 1024px)": {
            slides: {
              origin: "center",
              perView: 3.5,
              spacing: 0,
            },
          },
        },
      },
      [autoplay]
    );

    const keenSliderPrevious = document.getElementById("keen-slider-previous");
    const keenSliderNext = document.getElementById("keen-slider-next");
    keenSliderPrevious?.addEventListener("click", () => keenSlider.prev());
    keenSliderNext?.addEventListener("click", () => keenSlider.next());
  });
</script>
