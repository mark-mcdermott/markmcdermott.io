---
const messages = [
  "Senior QA, aspiring dev",
  "Austin, TX",
  "MS in Software Engineering",
  "20+ years experience",
  "JavaScript, Ruby, Bash",
  "React, Vue, Astro, Node, Rails",
  "Postgres, MySQL, Snowflake",
  "Docker, AWS, Fly.io, Vercel",
  "Cypress, Playwright, CircleCI",
  "Claude, ChatGPT",
  "fun fact #1: My favorite dinosaur is kentrosaurus",
  "fun fact #2: I once lived in a bookstore in Paris for a couple months",
];
const marqueeItems = [...messages, ...messages]; // Duplicate for seamless loop
---

<section class="border-black/20 border-y">
  <div class="overflow-hidden py-2 relative landing-banner text-[#1e1e1e] dark:text-white">
    <!-- Edge gradient overlays -->
    <div
      aria-hidden="true"
      class="absolute inset-0 z-10 pointer-events-none sr-only"
    >
      <div
        class="absolute left-0 w-24 h-full bg-gradient-to-r from-black via-transparent"
      >
      </div>
      <div
        class="absolute right-0 w-24 h-full bg-gradient-to-l from-black via-transparent"
      >
      </div>
    </div>

    <!-- Marquee content -->
    <div
      class="flex w-max animate-marquee gap-6 whitespace-nowrap font-black tracking-widest uppercase"
    >
      {
        marqueeItems.map((msg, index) => (
          <>
            <span>{msg}</span>
            {index !== marqueeItems.length - 1 && (
              <span aria-hidden="true">✺</span>
            )}
          </>
        ))
      }
    </div>
  </div>
</section>
