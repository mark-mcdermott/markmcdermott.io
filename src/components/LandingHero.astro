---
import BgGrid from "./BgGrid.astro";
import LandingBanner from "./LandingBanner.astro";
---

<section class="landing-hero border-x border-b">
  <div class="bg-grid p-8 relative">
    <BgGrid />

    <h1
      class="uppercase relative hero-title"
      style="font-family: 'Geist', sans-serif; font-weight: 900; color: #1e1e1e;"
    >
      My buddy Claude & I are turning dreams into cross-platform apps.
    </h1>
  </div>
  <LandingBanner />
</section>

<style is:global>
  .hero-title {
    font-size: clamp(2rem, 6vw, 96px);
    letter-spacing: -1px;
    line-height: 66px;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: clamp(2rem, 7vw, 96px);
      letter-spacing: -4.8px;
    }
  }

  @media (min-width: 1024px) {
    .hero-title {
      line-height: 81px;
    }
  }

  @media (min-width: 1280px) {
    .hero-title {
      line-height: 96px;
    }
  }

  @media (min-width: 1536px) {
    .hero-title {
      font-size: clamp(2rem, 8vw, 96px);
    }
  }

  [data-theme="dark"] .landing-hero .hero-title {
    color: #e7e7d8 !important;
  }
</style>
