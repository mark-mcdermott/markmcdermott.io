---
import StarCount from './StarCount.astro';

interface Project {
  name: string;
  description: string;
  repo: string;
  url: string;
  language: string;
  langColor?: string;
  testsUrl?: string;
  longDescription?: string;
  highlights?: string[];
  role?: string;
}

interface Props {
  projects: Project[];
  showViewAll?: boolean;
  variant?: 'compact' | 'detailed';
  heading?: string;
}

const { projects, showViewAll = true, variant = 'compact', heading = 'Projects' } = Astro.props;
const isOdd = projects.length % 2 !== 0;
const useSlider = variant === 'compact' && isOdd;
---

<section class="projects">
  <div class="projects__header">
    <h2>{heading}</h2>
    {showViewAll && <a href="/projects" class="projects__view-all">View all &rarr;</a>}
  </div>
  {useSlider ? (
    <div class="projects__slider" data-slider>
      <div class="projects__track" data-track>
        {projects.map((project) => (
          <a href={project.url} target="_blank" rel="noopener" class="project-card">
            <span class="project-card__arrow">&#8599;</span>
            <h3>{project.name}</h3>
            <p class="project-card__desc">{project.description}</p>
            <div class="project-card__footer">
              <div class="project-card__meta">
                <span class="project-card__lang">
                  <span class="project-card__lang-name">{project.language}</span>
                </span>
                <StarCount repo={project.repo} />
              </div>
              {project.testsUrl && <p class="project-card__tests"><span class="project-card__tests-link" data-href={project.testsUrl}>view tests &rarr;</span></p>}
            </div>
          </a>
        ))}
      </div>
      <div class="projects__nav">
        <button class="projects__arrow projects__arrow--prev" data-prev aria-label="Previous projects"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 113 155" width="16" height="22" fill="var(--color-text)" style="transform:scaleX(-1)"><polygon points="43 0 43.02 13.97 56.97 14.03 57.03 27.97 70.97 28.03 71.03 41.97 84.97 42.03 85.03 55.97 98.97 56.03 99.03 69.98 113 70 113 85 99.03 85.02 98.97 98.97 85.03 99.03 84.97 112.97 71.03 113.03 70.97 126.97 57.03 127.03 56.97 140.97 43.02 141.03 43 155 0 155 0 126 13.97 125.98 14.03 112.03 27.97 111.97 28.03 98.03 41.97 97.97 42.03 84.03 55.97 83.97 55.97 71.03 42.03 70.97 41.97 57.03 28.03 56.97 27.97 43.03 14.03 42.97 13.97 29.02 0 29 0 0 43 0"/></svg></button>
        <button class="projects__arrow projects__arrow--next" data-next aria-label="Next projects"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 113 155" width="16" height="22" fill="var(--color-text)"><polygon points="43 0 43.02 13.97 56.97 14.03 57.03 27.97 70.97 28.03 71.03 41.97 84.97 42.03 85.03 55.97 98.97 56.03 99.03 69.98 113 70 113 85 99.03 85.02 98.97 98.97 85.03 99.03 84.97 112.97 71.03 113.03 70.97 126.97 57.03 127.03 56.97 140.97 43.02 141.03 43 155 0 155 0 126 13.97 125.98 14.03 112.03 27.97 111.97 28.03 98.03 41.97 97.97 42.03 84.03 55.97 83.97 55.97 71.03 42.03 70.97 41.97 57.03 28.03 56.97 27.97 43.03 14.03 42.97 13.97 29.02 0 29 0 0 43 0"/></svg></button>
      </div>
    </div>
  ) : (
    <div class="projects__grid">
      {projects.map((project) => (
        <a href={project.url} target="_blank" rel="noopener" class="project-card">
          <span class="project-card__arrow">&#8599;</span>
          <h3>{project.name}</h3>
          {variant === 'detailed' && project.longDescription ? (
            <p class="project-card__desc">{project.longDescription}</p>
          ) : (
            <p class="project-card__desc">{project.description}</p>
          )}
          {variant === 'detailed' && project.highlights && (
            <ul class="project-card__highlights">
              {project.highlights.map((h) => <li>{h}</li>)}
            </ul>
          )}
          {variant === 'detailed' && project.role && (
            <p class="project-card__role"><span class="project-card__role-label">Role:</span> {project.role}</p>
          )}
          <div class="project-card__footer">
            <div class="project-card__meta">
              <span class="project-card__lang">
                <span class="project-card__lang-name">{project.language}</span>
              </span>
              <StarCount repo={project.repo} />
            </div>
            {project.testsUrl && <p class="project-card__tests"><span class="project-card__tests-link" data-href={project.testsUrl}>view tests &rarr;</span></p>}
          </div>
        </a>
      ))}
    </div>
  )}
</section>

<style lang="scss">
  @use '../styles/abstracts' as *;

  .projects {
    padding-top: $spacing-unit * 2;
    padding-bottom: $spacing-unit * 4;

    .projects__header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: $spacing-unit * 3;
    }

    h2 {
      font-size: $font-size-md;
      margin: 0;
      letter-spacing: normal;
      word-spacing: normal;
      line-height: $line-height-base * 0.8;
    }

    .projects__view-all {
      @include c64-type;
      font-size: $font-size-xs;
      color: var(--color-text);
      text-decoration: none;
      letter-spacing: 0;

      &:hover {
        color: var(--color-link);
      }
    }

    h3 {
      letter-spacing: 0.005em;
    }

    .project-card__lang-name {
      font-family: 'Rubik', sans-serif;
      font-size: 0.75rem;
      letter-spacing: -0.01em;
      font-weight: 400;
      word-spacing: 0.1em;
    }
  }

  // --- Even layout: grid ---
  .projects__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: $spacing-unit * 2;

    @include mobile {
      grid-template-columns: 1fr;
    }
  }

  // --- Odd layout: slider ---
  .projects__slider {
    overflow: hidden;
    padding: 6px;
    margin: -6px;
    position: relative;
  }

  .projects__track {
    display: flex;
    gap: $spacing-unit * 2;
    transition: transform 0.3s ease;

    .project-card {
      flex: 0 0 calc(50% - #{$spacing-unit});
      padding-left: $spacing-unit * 5;
      padding-right: $spacing-unit * 5;
      padding-top: 13px;
      padding-bottom: 10px;
      margin-bottom: 0;
    }

    @include mobile {
      flex-direction: column;
      transform: none !important;

      .project-card {
        flex: none;
        padding-left: $spacing-unit * 2;
        padding-right: $spacing-unit * 2;
      }
    }
  }

  .projects__nav {
    display: flex;
    justify-content: space-between;
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    pointer-events: none;

    @include mobile {
      display: none;
    }
  }

  .projects__arrow {
    background: none;
    border: none;
    cursor: pointer;
    padding: 16px;
    color: var(--color-text);
    opacity: 0.7;
    pointer-events: auto;

    &--prev {
      margin-left: 6px;
    }

    &--next {
      margin-right: 6px;
    }

    &:hover {
      opacity: 1;

      svg {
        fill: var(--color-link);
      }
    }
  }

  // --- Shared card styles ---
  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-text);
    padding: $spacing-unit * 2;
    margin-bottom: 1rem;
    border: 2px dashed var(--color-text);
    outline: 2px solid var(--color-text);
    outline-offset: 3px;
    border-radius: 0;

    &:hover {
      color: var(--color-link);
      border-color: var(--color-link);
      outline-color: var(--color-link);
    }

    h3 {
      font-size: $font-size-base;
      margin: 0 0 $spacing-unit;
    }

    &__arrow {
      @include c64-type;
      font-weight: 400;
      font-size: 1.5em;
      line-height: 0.3em;
      position: absolute;
      top: 8px;
      right: 8px;
    }

    &__desc {
      font-size: $font-size-sm;
      font-weight: 400;
      line-height: $line-height-base;
      margin: 0;
    }

    &__highlights {
      list-style: none;
      margin: $spacing-unit 0 0;
      padding: 0;

      li {
        font-size: $font-size-sm;
        font-weight: 400;
        line-height: $line-height-base;
        padding-left: 1em;
        position: relative;
        margin-bottom: 2px;

        &::before {
          content: '>';
          position: absolute;
          left: 0;
          top: 5px;
          @include c64-type;
          font-size: 0.7rem;
        }
      }
    }

    &__role {
      @include c64-type;
      font-size: $font-size-xs;
      margin: $spacing-unit 0 0;
      opacity: 0.6;
    }

    &__role-label {
      text-transform: uppercase;
    }

    &__footer {
      margin-top: auto;
      padding-top: $spacing-unit;
    }

    &__meta {
      @include c64-type;
      text-transform: capitalize;
      display: flex;
      align-items: center;
      gap: $spacing-unit * 2;
      font-size: $font-size-xs;
    }

    &__lang {
      display: flex;
      align-items: center;
      gap: 0.4em;
    }

    &__tests {
      text-align: right;
      margin: $spacing-unit 0 0;
      font-size: 0.75rem;
    }

    &__tests-link {
      color: var(--color-link);
      cursor: pointer;

      &:hover {
        text-decoration: underline;
      }
    }

  }
</style>

<script>
  const slider = document.querySelector<HTMLElement>('[data-slider]');
  if (slider) {
    const track = slider.querySelector<HTMLElement>('[data-track]');
    const prevBtn = slider.querySelector<HTMLElement>('[data-prev]');
    const nextBtn = slider.querySelector<HTMLElement>('[data-next]');
    if (!track || !prevBtn || !nextBtn) throw new Error('Slider elements missing');

    let sliding = false;

    function getCardWidth() {
      const card = track.children[0] as HTMLElement;
      const gap = parseFloat(getComputedStyle(track).columnGap) || 0;
      return card.offsetWidth + gap;
    }

    nextBtn.addEventListener('click', () => {
      if (sliding) return;
      sliding = true;
      const cardWidth = getCardWidth();
      track.style.transition = 'transform 0.3s ease';
      track.style.transform = `translateX(-${cardWidth}px)`;
      track.addEventListener('transitionend', () => {
        track.style.transition = 'none';
        track.style.transform = 'translateX(0)';
        track.appendChild(track.children[0]);
        sliding = false;
      }, { once: true });
    });

    prevBtn.addEventListener('click', () => {
      if (sliding) return;
      sliding = true;
      const cardWidth = getCardWidth();
      const last = track.children[track.children.length - 1];
      track.style.transition = 'none';
      track.insertBefore(last, track.children[0]);
      track.style.transform = `translateX(-${cardWidth}px)`;
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          track.style.transition = 'transform 0.3s ease';
          track.style.transform = 'translateX(0)';
          track.addEventListener('transitionend', () => {
            sliding = false;
          }, { once: true });
        });
      });
    });
  }

  document.querySelectorAll('.project-card__tests-link').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const href = (el as HTMLElement).dataset.href;
      if (href) window.open(href, '_blank');
    });
  });
</script>
