---
import DefaultLayout from '../layouts/DefaultLayout.astro';

const photos = [
  { src: '/images/photos/puppies.jpeg', alt: 'Shih-tzu puppies' },
  { src: '/images/photos/mission-control.jpeg', alt: 'NASA Mission Control' },
  { src: '/images/photos/beach-bar.jpeg', alt: 'Beach bar view' },
  { src: '/images/photos/pterodactyl.png', alt: 'Riding a pterodactyl' },
  { src: '/images/photos/color-shadows.jpeg', alt: 'Color shadow exhibit' },
  { src: '/images/photos/sunset.jpeg', alt: 'Lake sunset' },
  { src: '/images/photos/sorcerers-wrapped.jpg', alt: 'Spotify Wrapped - The Sorcerers' },
  { src: '/images/photos/ball-pit.jpeg', alt: 'Ball pit' },
  { src: '/images/photos/beach-resort.jpeg', alt: 'Beach resort' },
  { src: '/images/photos/streetlight.jpeg', alt: 'Streetlight and moon' },
  { src: '/images/photos/silhouettes.jpeg', alt: 'Neon silhouettes' },
  { src: '/images/photos/mini-cow.jpeg', alt: 'Mini cow' },
  { src: '/images/photos/fly-me-to-the-moon.jpg', alt: 'Fly Me to the Moon sheet music' },
  { src: '/images/photos/jeep-ducks.jpeg', alt: 'Jeep with ducks' },
  { src: '/images/photos/rainbow-flags.jpeg', alt: 'Rainbow and flags' },
  { src: '/images/photos/palm-shadow.jpeg', alt: 'Palm tree shadow on beach' },
  { src: '/images/photos/sorcerers-wrapped-2.png', alt: 'Spotify Wrapped - The Sorcerers 2' },
  { src: '/images/photos/antigua-statue.jpeg', alt: 'Antigua statue' },
];
---

<DefaultLayout pageTitle="Photos">
  <article>

    <h2>Photos</h2>
    <div class="masonry">
      {photos.map((photo) => (
        <div class="masonry__item">
          <img src={photo.src} alt={photo.alt} loading="lazy" />
        </div>
      ))}
    </div>

  </article>
</DefaultLayout>

<style lang="scss">
  @use '../styles/abstracts' as *;

  .masonry {
    columns: 3;
    column-gap: $spacing-unit * 2;

    @include mobile {
      columns: 2;
    }
  }

  .masonry__item {
    break-inside: avoid;
    margin-bottom: $spacing-unit * 2;

    img {
      display: block;
      width: 100%;
      height: auto;
      border: 2px dashed var(--color-text);
      outline: 2px solid var(--color-text);
      outline-offset: 3px;
    }
  }
</style>
