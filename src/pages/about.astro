---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import TravelMap from '../components/TravelMap.astro';

---

<DefaultLayout pageTitle="About">
  <article>

    <h2>About Me</h2>
    <p>I build and test web applications with a focus on automation and developer tooling. Currently a Senior QA Engineer at <a href="https://doximity.com">Doximity</a>, transitioning into full-stack TypeScript development.</p>
    <p>I hold a Master's degree in Software Engineering and have spent my career ensuring software quality across various platforms and technologies. My experience spans from manual testing to automated test frameworks, and I'm now channeling that expertise into development.</p>
    <p>When I'm not coding, I'm spending time with my family and our two shih-tzus or hopefully <a href="/photos">travelling</a>. When I have time, I tinker with mechanical keyboards and study Spanish.</p>

    <div class="photo-gallery">
      <div class="photo-gallery__item">
        <div class="photo-gallery__frame">
          <img src="/images/hawaii.png" alt="Hawaii" />
        </div>
        <span class="photo-gallery__caption">Hawaii 2018</span>
      </div>
      <div class="photo-gallery__item">
        <div class="photo-gallery__frame">
          <img src="/images/squad.png" alt="My Squad" />
        </div>
        <span class="photo-gallery__caption">My Squad</span>
      </div>
      <div class="photo-gallery__item">
        <div class="photo-gallery__frame">
          <img src="/images/snowboarding.png" alt="Snowboarding" />
        </div>
        <span class="photo-gallery__caption">Snowboarding</span>
      </div>
    </div>

    <h2>Experience</h2>
    <div class="timeline-grid">
      <ol class="timeline timeline--left">
        <li class="timeline__item">
          <img src="/images/logos/freelance.svg" alt="Freelance" class="timeline__logo" />
          <span class="timeline__date">2016</span>
          <a href="https://markmcdermott.io" class="timeline__role" target="_blank" rel="noopener noreferrer">Freelance</a>
          <span class="timeline__company">Front-end Developer</span>
        </li>
        <li class="timeline__item">
          <img src="/images/logos/kasasa.png" alt="Kasasa" class="timeline__logo" />
          <span class="timeline__date">2011 — 2015</span>
          <a href="https://www.kasasa.com/" class="timeline__role" target="_blank" rel="noopener noreferrer">Kasasa</a>
          <span class="timeline__company">Front-end Programmer</span>
        </li>
        <!-- <li class="timeline__item">
          <img src="/images/logos/uship.png" alt="uShip" class="timeline__logo" />
          <span class="timeline__date">2011</span>
          <span class="timeline__role">uShip</span>
          <span class="timeline__company">Front-end Web Developer</span>
        </li> -->
        <li class="timeline__item">
          <img src="/images/logos/s-collective.png" alt="S Collective" class="timeline__logo" />
          <span class="timeline__date">2009 — 2011</span>
          <span class="timeline__role">S Collective</span>
          <span class="timeline__company timeline__company--defunct">Front-end Web Developer</span>
        </li>
        <li class="timeline__item">
          <img src="/images/logos/freelance.svg" alt="Freelance" class="timeline__logo" />
          <span class="timeline__date">2006 — 2008</span>
          <a href="https://markmcdermott.io" class="timeline__role" target="_blank" rel="noopener noreferrer">Freelance</a>
          <span class="timeline__company">Front-end Developer</span>
        </li>
      </ol>
      <ol class="timeline timeline--right">
        <li class="timeline__item">
          <img src="/images/logos/doximity.png" alt="Doximity" class="timeline__logo" />
          <span class="timeline__date">2020 — Current</span>
          <a href="https://www.doximity.com/" class="timeline__role" target="_blank" rel="noopener noreferrer">Doximity</a>
          <span class="timeline__company">Senior QA Engineer</span>
        </li>
        <li class="timeline__item">
          <img src="/images/logos/axzon.png" alt="Axzon" class="timeline__logo" />
          <span class="timeline__date">2019</span>
          <a href="https://www.axzon.com/" class="timeline__role" target="_blank" rel="noopener noreferrer">Axzon</a>
          <span class="timeline__company">Automation Engineer</span>
        </li>
        <li class="timeline__item">
          <img src="/images/logos/kasasa.png" alt="Kasasa" class="timeline__logo" />
          <span class="timeline__date">2019</span>
          <a href="https://www.kasasa.com/" class="timeline__role" target="_blank" rel="noopener noreferrer">Kasasa</a>
          <span class="timeline__company">Front-end Programmer</span>
        </li>
        <li class="timeline__item">
          <img src="/images/logos/schwab.jpg" alt="Charles Schwab" class="timeline__logo" />
          <span class="timeline__date">2017 — 2019</span>
          <a href="https://www.schwab.com/" class="timeline__role" target="_blank" rel="noopener noreferrer">Charles Schwab</a>
          <span class="timeline__company">Midlevel Developer</span>
        </li>
      </ol>
    </div>

    <h2>Testimonials</h2>
    <div class="testimonials">
      <blockquote class="testimonial">
        <p>I've worked with Mark McDermott for several years and wanted to write briefly on the huge impact that he has had on several teams that I've worked on. He's a great teammate and an incredible engineer. I've heavily relied on Mark's technical knowledge and drive. Mark has consistently distinguished himself as someone who gets lots of work done often while under challenging circumstances. His technical capacity, thoughtful approach, and incredible attitude have made him a person I look forward to working with. I ask for him by name for our most challenging and demanding projects.</p>
        <footer><strong>Christopher Sigg</strong> — Senior Software Engineer I, Doximity</footer>
      </blockquote>
      <blockquote class="testimonial">
        <p>I've worked with Mark for a few years, most of that time on a high-pressure, high-stakes client-facing project, and he's been an invaluable, trustworthy contributor to the team. He's reliable under pressure and collaborates well with engineering, even when we've made his job tough with complex requirements! Mark is quick, asks thorough questions that surface edge cases early, and has helped us prevent countless bugs before they became real problems — everything from typos to performance issues to thoughtful UI improvement suggestions, and everything in between. Working with him has made shipping complex features smoother and less stressful, and he's someone I can always trust when quality really matters.</p>
        <footer><strong>Claire Pengelly</strong> — Senior Software Engineer I, Doximity</footer>
      </blockquote>
    </div>

    <h2>Travel</h2>
    <p>I've been lucky to have travelled a lot. I once travelled all the way around the world <a href="https://www.semesteratsea.org">on a ship</a> and I once lived in a <a href="https://www.shakespeareandcompany.com/">bookstore in Paris</a> for a couple months. Here are all places I've visited over the years.</p>
    <TravelMap />
  </article>
</DefaultLayout>

<script>
  document.querySelectorAll('.photo-gallery__frame').forEach((frame) => {
    frame.addEventListener('click', () => {
      frame.classList.toggle('is-active');
    });
  });
</script>

<style lang="scss">
  @use '../styles/abstracts' as *;

  article {
    padding-bottom: $spacing-unit * 5;

    p {
      font-size: $font-size-md;
      line-height: $line-height-base;
      letter-spacing: $letter-spacing-body;
      margin-bottom: $spacing-unit * 2.5;
    }

    h2:not(:first-child) {
      margin-top: 48px;
    }
  }

  $logo-size: 36px;
  $timeline-gap: $spacing-unit * 6;
  $line-left: $logo-size * 0.5 - 1px;

  .timeline-grid {
    display: grid;
    grid-template-columns: 285px 1fr;
    gap: 0 $timeline-gap;
    position: relative;
    margin-top: 26px;
    margin-bottom: 20px;
    width: fit-content;
    margin-left: auto;
    margin-right: auto;

    // vertical connector line in center gap
    &::before {
      content: '';
      position: absolute;
      left: 245px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: var(--color-text);
    }

    @include mobile {
      grid-template-columns: 1fr;
      gap: 0;

      &::before {
        display: none;
      }
    }
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    padding-left: $logo-size + $spacing-unit * 2;

    @include mobile {
      width: fit-content;
      margin: 0 auto;
    }
  }

  // Left column (older jobs) — line extends above first circle to top
  .timeline--left {
    grid-column: 1;
    grid-row: 1;
    align-self: stretch;
    padding-top: $spacing-unit * 2;
    padding-bottom: $spacing-unit * 2;

    // vertical line
    &::before {
      content: '';
      position: absolute;
      left: $line-left;
      top: 0;
      bottom: $logo-size * 0.5;
      width: 2px;
      background: var(--color-text);
    }

    // horizontal bridge at top → center
    &::after {
      content: '';
      position: absolute;
      top: 0;
      left: $line-left;
      right: 40px;
      height: 2px;
      background: var(--color-text);
    }

    @include mobile {
      grid-column: 1;
      grid-row: 2;
      padding-top: 0;

      &::before {
        top: 0;
      }

      &::after {
        display: none;
      }
    }
  }

  // Right column (recent jobs) — line extends below last circle to bottom
  .timeline--right {
    grid-column: 2;
    grid-row: 1;
    align-self: stretch;
    padding-top: $spacing-unit * 2;
    padding-bottom: $spacing-unit * 2;

    // vertical line
    &::before {
      content: '';
      position: absolute;
      left: $line-left;
      top: $logo-size * 0.5;
      bottom: 0;
      width: 2px;
      background: var(--color-text);
    }

    // horizontal bridge at bottom ← center
    &::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: -($timeline-gap + 40px);
      width: $timeline-gap + 40px + $line-left + 1px;
      height: 2px;
      background: var(--color-text);
    }

    @include mobile {
      grid-column: 1;
      grid-row: 1;
      padding-bottom: $spacing-unit * 3;

      &::before {
        bottom: 0;
      }

      &::after {
        display: none;
      }
    }
  }

  .timeline__item {
    position: relative;
    padding-bottom: $spacing-unit * 3;

    &:last-child {
      padding-bottom: 0;
    }
  }

  // mask line below last circle on left column
  .timeline--left .timeline__item:last-child::after {
    content: '';
    position: absolute;
    left: -($logo-size + $spacing-unit * 2);
    top: $logo-size * 0.5;
    bottom: 0;
    width: $logo-size;
    background: var(--color-bg);
    z-index: 0;
  }

  .timeline__logo {
    position: absolute;
    left: -($logo-size + $spacing-unit * 2);
    top: 0;
    width: $logo-size;
    height: $logo-size;
    object-fit: contain;
    border-radius: 50%;
    border: 2px solid var(--color-text);
    background: var(--color-bg);
    padding: 5px;
    filter: grayscale(100%);
    z-index: 1;

    :global([data-theme='dark']) & {
      background: white;
      border-color: black;
      filter: grayscale(100%) invert(1);
    }

    :global([data-theme='c64']) & {
      background: white;
      border-color: black;
      filter: grayscale(100%) invert(1) sepia(1) hue-rotate(175deg) saturate(3);
    }
  }

  .timeline__date {
    @include c64-type;
    font-size: $font-size-xs;
    display: block;
    margin-bottom: 2px;
  }

  .timeline__role {
    font-size: $font-size-md;
    font-weight: bold;
    display: block;
    letter-spacing: $letter-spacing-body;
    color: var(--color-text);
    text-decoration: none;
  }

  a.timeline__role::after {
    content: '';
    position: absolute;
    top: 0;
    left: -($logo-size + $spacing-unit * 2);
    right: 0;
    bottom: 0;
    z-index: 2;
  }

  .timeline__item:has(a.timeline__role) {
    cursor: pointer;

    &:hover .timeline__role {
      color: var(--color-link);
    }

    &:hover .timeline__date {
      color: var(--color-text);

      :global([data-theme='c64']) & {
        color: var(--color-link);
      }
    }

    &:hover .timeline__company {
      font-weight: bold;
      color: var(--color-text);
      opacity: 1;
    }

    &:hover .timeline__logo {
      filter: none;
      border-color: var(--color-link);
    }
  }

  // S Collective (defunct — no link)
  .timeline__item:not(:has(a.timeline__role)) {
    cursor: not-allowed;

    // Overlay to capture hover across the full item (matching the stretched link on linked items)
    &::after {
      content: '';
      position: absolute;
      top: 0;
      left: -($logo-size + $spacing-unit * 2);
      right: 0;
      bottom: 0;
      z-index: 2;
    }

    &:hover .timeline__logo {
      filter: grayscale(100%) brightness(1.6) contrast(0.5);
      border-color: hsla(0, 0%, 19%, 0.3);
      background: var(--color-bg);
      z-index: 2;
    }

    &:hover .timeline__date,
    &:hover .timeline__role,
    &:hover .timeline__company:not(.timeline__company--defunct) {
      opacity: 0.4;
    }
  }

  // Freelance logo: match nav logo appearance in dark mode (no invert)
  .timeline__item:has(img[src*="freelance"]) .timeline__logo {
    :global([data-theme='dark']) & {
      filter: grayscale(100%);
      background: black;
      border-color: white;
    }
  }

  // Freelance logo: white circle backup behind the img for hover colorizing
  .timeline__item:has(img[src*="freelance"]) {
    &::before {
      content: '';
      position: absolute;
      left: -($logo-size + $spacing-unit * 2);
      top: 0;
      width: $logo-size;
      height: $logo-size;
      border-radius: 50%;
      border: 2px solid transparent;
      background: var(--color-bg);
      padding: 5px;
      z-index: 1;
      pointer-events: none;
    }

    &:hover::before {
      border-color: var(--color-link);

      :global([data-theme='dark']) & {
        border-color: transparent;
      }
    }

    &:hover .timeline__logo {
      background: transparent;
      border-color: transparent;
      filter: brightness(0) saturate(100%) invert(52%) sepia(79%) saturate(2476%) hue-rotate(176deg) brightness(93%) contrast(87%);

      :global([data-theme='dark']) & {
        background: white;
        border-color: var(--color-link);
        filter: none;
      }
    }
  }

  .timeline__company {
    font-size: $font-size-sm;
    display: block;
    color: var(--color-text);
    opacity: 0.7;
    letter-spacing: $letter-spacing-body;
  }

  .timeline__company--defunct {
    font-size: 0;

    &::after {
      content: 'Front-end Web Developer';
      font-size: $font-size-sm;
    }
  }

  .timeline__item:hover .timeline__company--defunct {
    opacity: 1;

    &::after {
      content: '(Now Defunct)';
      color: var(--color-text);
      font-weight: bold;
    }
  }

  // --- Testimonials ---
  .testimonials {
    margin-top: 26px;
    margin-bottom: 20px;
  }

  .testimonial {
    border-left: 2px solid var(--color-text);
    padding-left: $spacing-unit * 3;
    margin: 0 0 32px 0;

    &:last-child {
      margin-bottom: 0;
    }

    p {
      font-size: 1rem;
      line-height: $line-height-base;
      letter-spacing: $letter-spacing-body;
      margin-bottom: $spacing-unit;
    }

    footer {
      @include c64-type;
      font-size: $font-size-xs;
      opacity: 0.7;
    }
  }

  // --- Photo Gallery (CRT monitors) ---
  .photo-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: $spacing-unit * 2;
    margin-top: 32px;
    margin-bottom: $spacing-unit * 4;

    @include mobile {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin-left: auto;
      margin-right: auto;
    }
  }

  .photo-gallery__frame {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 2px solid var(--color-text);
    border-radius: 4px;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(100%) contrast(1.8) brightness(1.05);
      transition: filter 0.4s ease;
    }

    // CRT scanline overlay
    &::after {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        to bottom,
        transparent 0px,
        transparent 2px,
        rgba(0, 0, 0, 0) 2px,
        rgba(0, 0, 0, 0.5) 4px
      );
      pointer-events: none;
      opacity: $opacity-overlay;
      transition: opacity 0.4s ease;
    }

    &:hover img,
    &.is-active img {
      filter: grayscale(0%) contrast(1) brightness(1);
    }

    &:hover::after,
    &.is-active::after {
      opacity: 0;
    }

    // Dark mode
    :global([data-theme='dark']) & img {
      filter: grayscale(100%) contrast(1.8) brightness(1.15);
    }

    :global([data-theme='dark']) &:hover img,
    :global([data-theme='dark']) &.is-active img {
      filter: grayscale(0%) contrast(1) brightness(1);
    }

    // C64 mode
    :global([data-theme='c64']) & img {
      filter: grayscale(100%) sepia(100%) hue-rotate(180deg) saturate(2) brightness(1.1);
    }

    :global([data-theme='c64']) &:hover img,
    :global([data-theme='c64']) &.is-active img {
      filter: grayscale(0%) contrast(1) brightness(1);
    }
  }

  .photo-gallery__caption {
    @include c64-type;
    font-size: $font-size-xs;
    display: block;
    text-align: center;
    margin-top: $spacing-unit;
    opacity: 0.7;
  }
</style>