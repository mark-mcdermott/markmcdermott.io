---
import Layout from "../layouts/Layout.astro";
import Chip from "../components/Chip.astro";
// import BgGrid from "../components/BgGrid.astro";
// import AboutBanner from "../components/AboutBanner.astro";

const frontendSkills = ["React", "JavaScript", "TypeScript", "Tailwind CSS", "Shadcn UI", "Astro", "Vue", "HTML5", "CSS3"];
const backendSkills = ["Node.js", "Ruby", "Rails", "Python", "PostgreSQL", "MySQL", "REST APIs", "C++", "C", "Java"];
const toolsSkills = ["Git", "Bash", "VS Code", "NeoVim", "Docker", "AWS", "Cypress", "Playwright", "Photoshop"];
---

<Layout
  title="Mark McDermott"
  description="Learn more about Mark McDermott - Senior QA Engineer and aspiring developer"
>
  <section class="border-x border-b py-20">
    <div class="max-w-6xl mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="text-white tracking-tight font-black text-4xl md:text-6xl lg:text-8xl mb-6">About</h1>
        <p class="text-xl text-base-content/70">
          Senior QA Engineer and aspiring developer based in Austin, TX.
        </p>
      </div>

    </div>
  </section>

  <!-- Old Hero Section - commented out for later
  <section class="border-x border-b">
    <div class="bg-grid relative">
      <BgGrid />

      <div class="relative">
        <img
          src="/images/pterodactyl.png"
          alt="Mark McDermott riding a pterodactyl"
          class="w-full h-auto"
        />

        <div class="absolute top-8 left-8 md:top-16 md:left-16">
          <div class="mb-4">
            <span
              class="text-orange uppercase tracking-wider text-sm font-mono bg-black/70 px-3 py-1 rounded"
              >About Me</span
            >
          </div>

          <h1
            class="tracking-tighter font-black uppercase text-4xl md:text-6xl lg:text-8xl mb-4 drop-shadow-lg"
            style="color: #1e1e1e;"
          >
            Cloud Solutions
          </h1>
        </div>

        <p
          class="absolute bottom-4 right-4 text-sm bg-black/70 px-4 py-2 rounded pterodactyl-caption"
        >
          Professional QA Engineer and amateur pterodactyl rider
        </p>
      </div>
    </div>
  </section>
  -->

  <!-- Main Content -->
  <section class="border-x">
    <div class="grid md:grid-cols-2 gap-0">
      <!-- Left Column - Bio -->
      <div class="p-8 md:p-16 lg:p-24 border-gray-400 lg:border-r">
        <h2
          class="text-white font-black uppercase text-2xl md:text-4xl mb-6 tracking-tight"
        >
          My Story
        </h2>

        <div class="space-y-4 text-eagle leading-relaxed">
          <p>
            I coded as a kid on my Commodore 64, making it boop, beep and flash.
            I didn't touch much code again until my early 20s, when I started
            building websites for non-profits and small businesses for fun.
          </p>
          <p>
            A few years later I went full time and started learning the details
            of HTML, CSS and JavaScript. I've mostly worked QA since then, but I
            did have a handful of stints doing light frontend dev work. I also
            did some devops/SDET-type work, setting up a CI/CD pipeline and
            writing Java tests.
          </p>

          <p>
            I specialize in building modern web applications using JavaScript,
            React, and other fun technologies I can get my hands on. Every
            project is an opportunity to learn something new.
          </p>

          <p>
            When I'm not coding, you'll find me with my family, my dogs or maybe
            riding a pterodactyl.
          </p>
        </div>
      </div>

      <!-- Right Column - Skills -->
      <div class="p-8 md:p-16 lg:p-24">
        <h2
          class="text-white font-black uppercase text-2xl md:text-4xl mb-6 tracking-tight"
        >
          Expertise
        </h2>

        <div class="space-y-6">
          <div>
            <h3 class="text-orange font-mono uppercase text-sm mb-3 mt-8 tracking-wider">
              Frontend
            </h3>
            <div class="flex flex-wrap gap-2 justify-center">
              {frontendSkills.map((skill) => <Chip label={skill} />)}
            </div>

            <div>
              <h3 class="text-orange font-mono uppercase text-sm mb-3 mt-8 tracking-wider">
                Backend
              </h3>
              <div class="flex flex-wrap gap-2 justify-center">
                {backendSkills.map((skill) => <Chip label={skill} />)}
              </div>
            </div>

            <div>
              <h3 class="text-orange font-mono uppercase text-sm mb-3 mt-8 tracking-wider">
                Tools
              </h3>
              <div class="flex flex-wrap gap-2 justify-center">
                {toolsSkills.map((skill) => <Chip label={skill} />)}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats Section -->
    <div>
      <div class="grid grid-cols-2 lg:grid-cols-4">
        <div
          class="p-8 md:p-12 text-center border-gray-400 border-t border-r border-b"
        >
          <div class="text-orange text-4xl md:text-5xl font-black mb-3">
            20+
          </div>
          <p class="text-eagle uppercase text-sm tracking-wider font-mono">
            Years Experience
          </p>
        </div>

        <div
          class="p-8 md:p-12 text-center border-gray-400 border-t border-b lg:border-r"
        >
          <div class="text-orange text-4xl md:text-5xl font-black mb-3">
            2,000+
          </div>
          <p class="text-eagle uppercase text-sm tracking-wider font-mono">
            Jira Stories
          </p>
        </div>

        <div
          class="p-8 md:p-12 text-center border-gray-400 border-r border-b lg:border-t"
        >
          <div class="text-orange text-4xl md:text-5xl font-black mb-3">
            20,000+
          </div>
          <p class="text-eagle uppercase text-sm tracking-wider font-mono">
            Commits
          </p>
        </div>

        <div
          class="p-8 md:p-12 text-center border-gray-400 border-b lg:border-t"
        >
          <div class="text-orange text-4xl md:text-5xl font-black mb-3">∞</div>
          <p class="text-eagle uppercase text-sm tracking-wider font-mono">
            Cups of Coffee
          </p>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* Ensure text colors work in both light and dark themes */
    .text-orange {
      color: #ea4125;
    }

    .text-eagle {
      color: #1e1e1e;
    }

    .text-white {
      color: #1e1e1e;
    }

    /* Pterodactyl caption should always be white */
    .pterodactyl-caption {
      color: #ffffff;
    }

    .back-link {
      font-size: 0.875rem;
      font-weight: 600;
    }

    .back-link:hover {
      color: #ea4125;
    }
  </style>

  <style is:global>
    [data-theme="dark"] .about-hero .about-hero-title {
      color: #e7e7d8 !important;
    }

    [data-theme="dark"] .text-white {
      color: #e7e7d8 !important;
    }

    [data-theme="dark"] .text-eagle {
      color: #afac95 !important;
    }

    [data-theme="dark"] .text-orange {
      color: #ea4125 !important;
    }

    [data-theme="dark"] .pterodactyl-caption {
      color: #ffffff !important;
    }
  </style>
</Layout>
