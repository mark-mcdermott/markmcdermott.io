---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import ProjectsGrid from '../components/ProjectsGrid.astro';

const projects = [
  {
    name: 'xin',
    description: 'Built a local-first desktop notes app with Playwright E2E tests and Electron auto-updates.',
    longDescription: 'A local-first desktop notes app built with Electron and TypeScript. Notes are stored in a local SQLite database, so everything works offline with zero latency. The app includes a full auto-update system via GitHub Releases and comprehensive E2E test coverage with Playwright.',
    highlights: [
      'Local-first SQLite storage with zero cloud dependency',
      'Playwright E2E test suite with CI integration',
      'Electron auto-updates via GitHub Releases',
      'Claude-assisted development workflow',
    ],
    repo: 'mark-mcdermott/xin',
    url: 'https://github.com/mark-mcdermott/xin',
    language: 'Typescript \u00B7 Electron \u00B7 Playwright \u00B7 Claude',
    testsUrl: 'https://github.com/mark-mcdermott/xin/actions/workflows/test.yml',
  },
  {
    name: 'markmcdermott.io',
    description: 'Built an Astro portfolio with custom C64 UI and automated Playwright smoke tests.',
    longDescription: 'This portfolio site, built with Astro 5 and SCSS. Features a custom Commodore 64-inspired retro aesthetic with three theme modes (light, dark, and C64). Every component is hand-styled with no CSS framework — just SCSS modules, custom properties, and a thorough understanding of the cascade.',
    highlights: [
      'Custom C64 retro UI with CRT scanline effects',
      'Three theme modes: light, dark, and C64',
      'Playwright smoke tests for every page',
      'Astro 5 SSG with zero client-side JavaScript by default',
    ],
    repo: 'mark-mcdermott/markmcdermott.io',
    url: 'https://github.com/mark-mcdermott/markmcdermott.io',
    language: 'Typescript \u00B7 Astro \u00B7 Playwright \u00B7 Claude',
  },
  {
    name: 'puravida',
    description: 'Bash CLI for instant file scaffolding and multi-line insertion. Daily driver for fast note and project setup.',
    longDescription: 'A zero-dependency Bash CLI for instant file scaffolding and multi-line text insertion. Designed as a daily driver for quickly setting up project structures, creating templated files, and inserting boilerplate code. Handles edge cases like nested directories and special characters without external tools.',
    highlights: [
      'Instant file and directory scaffolding',
      'Multi-line insertion with heredoc support',
      'Zero external dependencies — pure Bash',
      'Daily driver for note-taking and project setup',
    ],
    repo: 'mark-mcdermott/puravida',
    url: 'https://github.com/mark-mcdermott/puravida',
    language: 'Bash',
  },
]
---

<DefaultLayout pageTitle="Projects">
  <section class="projects-intro">
    <p>I build tools that make development faster and more reliable. Each project emphasizes thorough testing, clean architecture, and practical utility — things I've come to value after years in QA and engineering.</p>
  </section>
  <ProjectsGrid projects={projects} showViewAll={false} variant="detailed" />
</DefaultLayout>

<style lang="scss">
  @use '../styles/abstracts' as *;

  .projects-intro {
    margin-bottom: $spacing-unit * 2;

    p {
      font-size: $font-size-md;
      line-height: $line-height-base;
      letter-spacing: $letter-spacing-body;
    }
  }
</style>
