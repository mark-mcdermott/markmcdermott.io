---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import SkillBadge from "../../components/SkillBadge.astro";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async ({ paginate }) => {
  const blogPosts = await getCollection("blog");

  // Sort by publish date, most recent first
  const sortedPosts = blogPosts.sort(
    (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
  );

  return paginate(sortedPosts, { pageSize: 9 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

function formatDate(date: Date | string) {
  const d = new Date(date);
  return d.toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
}
---

<Layout
  title="Mark McDermott"
  description="Read my latest blog posts and articles"
>
  <main class="py-20 border-x border-b">
    <div class="max-w-6xl mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-16">
      <h1 class="text-white tracking-tight font-black text-4xl md:text-6xl lg:text-8xl mb-6">Blog</h1>
      <p class="text-xl text-base-content/70">
        Helpful snippets, weird syntax I'm trying to memorize and other miscellaneous thoughts on coding and AI.
      </p>
    </div>

    <!-- Back to Home -->
    <div class="mb-8">
      <a href="/" class="back-link inline-flex items-center gap-2 transition-colors">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Back to Home
      </a>
    </div>

    <!-- Blog Posts Grid -->
    {
      page.data.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-2xl text-base-content/60">
            No blog posts yet. Check back soon!
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {page.data.map((post) => (
            <article class="card bg-base-100 border" style="border-color: #999;">
              <div class="card-body">
                <time class="text-sm text-base-content/60">
                  {formatDate(post.data.publishDate)}
                </time>
                <h2 class="card-title blog-card-title transition-colors">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h2>
                <p class="text-base-content/80">{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-2">
                    {post.data.tags.map((tag) => (
                      <SkillBadge skill={tag} />
                    ))}
                  </div>
                )}
                <div class="card-actions justify-end mt-4">
                  <a href={`/blog/${post.id}`} class="bg-white duration-200 font-black text-[#1e1e1e] hover:bg-gray-200 px-6 py-2 rounded-lg border text-center text-xs uppercase" style="box-shadow: none !important; border-style: solid !important; border-color: #999;">
                    Read More
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )
    }

    <!-- Pagination -->
    {page.lastPage > 1 && (
      <nav class="flex justify-center items-center gap-4 mt-12">
        {page.url.prev ? (
          <a
            href={page.url.prev}
            class="pagination-link inline-flex items-center gap-2 px-4 py-2 rounded-lg border font-semibold text-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m15 18-6-6 6-6"></path>
            </svg>
            Previous
          </a>
        ) : (
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border font-semibold text-sm opacity-50 cursor-not-allowed">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m15 18-6-6 6-6"></path>
            </svg>
            Previous
          </span>
        )}

        <span class="text-sm text-base-content/70">
          Page {page.currentPage} of {page.lastPage}
        </span>

        {page.url.next ? (
          <a
            href={page.url.next}
            class="pagination-link inline-flex items-center gap-2 px-4 py-2 rounded-lg border font-semibold text-sm"
          >
            Next
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </a>
        ) : (
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border font-semibold text-sm opacity-50 cursor-not-allowed">
            Next
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </span>
        )}
      </nav>
    )}
    </div>
  </main>
</Layout>

<style>
  .text-white {
    color: #1e1e1e;
  }

  .blog-card-title:hover,
  .blog-card-title:hover a {
    color: #ea4125;
  }

  .back-link {
    font-size: 0.875rem;
    font-weight: 600;
  }

  .back-link:hover {
    color: #ea4125;
  }

  .pagination-link {
    border-color: #999;
    transition: all 0.2s;
  }

  .pagination-link:hover {
    background-color: #ea4125;
    border-color: #ea4125;
    color: white;
  }
</style>

<style is:global>
  [data-theme="dark"] .text-white {
    color: #e7e7d8 !important;
  }

  [data-theme="dark"] .blog-card-title:hover,
  [data-theme="dark"] .blog-card-title:hover a {
    color: #ea4125 !important;
  }
</style>
